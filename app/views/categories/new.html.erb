<h1 class = "text-center">Create a new category</h1>

 <div class="container">
    
    <div class="row col-md-offset-1">
        <div class = "col-md-9 ">
            <%= render 'shared/errors', obj: @category%>
            <%= form_for @category do|f|%>
                <div class = "form-group">
                    <%= f.label :name, "Category name", class: "control-label col-sm-2" %>
                    <div class = "input-group col-sm-10">
                        <%= f.text_field :name, class: "form-control", placeholder: "Enter a name" %>
                    </div> 
                </div>

                <div class = "form-group">
                    <%= f.submit class: "btn btn-lg"%>
                </div>
            <% end %>

            <%= link_to '[Cancel and return to articles listing]', articles_path%>
        </div>
    </div>
</div>
 <%#= form_for :article, url: {action: :update}, method: :patch do|f|%>
 <%#= form_for :article, url: article_path do|f|%>