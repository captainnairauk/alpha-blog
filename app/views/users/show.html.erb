<h1 class = "text-center"><%= @user.username%>'s profile</h1>

<%= gravatar_for @user, size: 200%>

<div class = "text-center">

    <%= link_to "Edit your profile", edit_user_path(@user), class: " {margin: 15px} btn btn-default btn-info"%>

</div>

<h3 class = "text-center">Articles</h3>

<%= render 'articles/article', obj: @user.articles%> 