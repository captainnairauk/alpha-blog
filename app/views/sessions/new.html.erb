<h1 class = "text-center">Log in </h1>

 <div class="container">
    
    <div class="row col-md-offset-1">
        <div class = "col-md-9 ">
            <%= form_for(:session, url: login_path) do|f|%>

                <div class = "form-group">
                    <%= f.label :email, class: "control-label col-sm-2" %>
                    <div class = "input-group col-sm-10">
                        <%= f.email_field :email, class: "form-control", placeholder: "Enter you email address" %>
                    </div>
                </div>

                <div class = "form-group">
                    <%= f.label :password, class: "control-label col-sm-2" %>
                    <div class = "input-group col-sm-10">
                        <%= f.password_field :password, class: "form-control", placeholder: "Enter your password" %>
                    </div>
                </div>


                <div class = "form-group">
                    <%= f.label :password_confirmation, class: "control-label col-sm-2" %>
                    <div class = "input-group col-sm-10">
                        <%= f.password_field :password_confirmation, class: "form-control", placeholder: "Re-enter your password" %>
                    </div>
                </div>

                <div class = "form-group">
                    <%= f.submit("Log in", class: "btn btn-lg")%>
                </div>
            <% end %>

            <%= link_to '[Cancel and return to articles listing]', articles_path%>
        </div>
    </div>
</div>
