<div class="container">
    
    <div class="row col-md-offset-1">
        <div class = "col-md-9 ">
            <%= render 'shared/errors'%>
            <%= form_for @article do|f|%>
                <div class = "form-group">
                    <%= f.label :title, class: "control-label col-sm-2" %>
                    <div class = "input-group col-sm-10">
                        <%= f.text_field :title, class: "form-control", placeholder: "Title of article" %>
                    </div> 
                </div>

                <div class = "form-group">
                    <%= f.label :description, class: "control-label col-sm-2" %>
                    <div class = "input-group col-sm-10">
                        <%= f.text_area :description, rows: 10, class: "form-control", placeholder: "Description of article" %>
                    </div>
                </div>

                <div class = "form-group">
                    <%= f.submit class: "btn btn-lg"%>
                </div>
            <% end %>

            <%= link_to '[Cancel and return to articles listing]', articles_path%>
        </div>
    </div>
</div>
 <%#= form_for :article, url: {action: :update}, method: :patch do|f|%>
 <%#= form_for :article, url: article_path do|f|%>